    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.atendimento ){",
        "\treturn {",
        "\t\t//map atendimento variable to expected task contract input",
        "\t\tatendimentoInput: {",
        "\t\t\tprecisaOutroServico: $data.atendimento.precisaOutroServico !== undefined ? $data.atendimento.precisaOutroServico : null,",
        "\t\t\tlenteContato: $data.atendimento.lenteContato !== undefined ? $data.atendimento.lenteContato : null,",
        "\t\t\tinformacoesExame: $data.atendimento.informacoesExame !== undefined ? $data.atendimento.informacoesExame : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "atendimento" : {
