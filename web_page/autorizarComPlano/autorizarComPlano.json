    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.atendimento ){",
        "\treturn {",
        "\t\t//map atendimento variable to expected task contract input",
        "\t\tatendimentoInput: {",
        "\t\t\tservicoAutorizadoPlano: $data.atendimento.servicoAutorizadoPlano !== undefined ? $data.atendimento.servicoAutorizadoPlano : null,",
